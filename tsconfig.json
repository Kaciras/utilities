{
	"compilerOptions": {
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ESNext",
		"types": ["node"],
		"lib": ["ESNext", "DOM"],
		"outDir": "lib",
		"emitDeclarationOnly": true,
		"declaration": true,
		"skipLibCheck": true,
		"useUnknownInCatchVariables": false,
		"allowImportingTsExtensions": true
	}
}
